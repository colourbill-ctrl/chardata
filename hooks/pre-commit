#!/bin/bash
# Pre-commit hook:
#   1. Rebuild WASM when C++ source changes (Emscripten lives in WSL).
#   2. Regenerate public/help.html when MANUAL.md or generate-help.js changes.
# Aborts the commit if either step fails or if help.html is hand-edited.

STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE '^gamut-wasm/'; then
    echo "gamut-wasm source changed — rebuilding WASM..."
    # Emscripten lives in WSL on this machine. If we're already inside WSL
    # (e.g., committing from a WSL shell), invoke the build script directly;
    # otherwise hop into WSL via the `wsl` interop.
    if [ -n "$WSL_DISTRO_NAME" ] || grep -qiE 'microsoft|wsl' /proc/version 2>/dev/null; then
        scripts/build-wasm.sh
    else
        wsl bash -c "cd /mnt/c/Users/colou/code/compwas && scripts/build-wasm.sh"
    fi
    if [ $? -ne 0 ]; then
        echo ""
        echo "ERROR: WASM build failed — commit aborted."
        echo "Fix the build error and try again."
        exit 1
    fi
    git add public/wasm/compwas-gamut.mjs public/wasm/compwas-gamut.wasm
    echo "WASM artifacts staged."
fi

HELP_SOURCE_CHANGED=false
if echo "$STAGED" | grep -qE '^(MANUAL\.md|scripts/generate-help\.js)$'; then
    HELP_SOURCE_CHANGED=true
fi

if echo "$STAGED" | grep -qE '^public/help\.html$' && [ "$HELP_SOURCE_CHANGED" = false ]; then
    echo ""
    echo "ERROR: public/help.html is auto-generated from MANUAL.md."
    echo "Edit MANUAL.md (or scripts/generate-help.js for diagrams/layout) instead."
    echo "Commit aborted."
    exit 1
fi

if [ "$HELP_SOURCE_CHANGED" = true ]; then
    echo "MANUAL.md or generate-help.js changed — regenerating help.html..."
    node scripts/generate-help.js
    if [ $? -ne 0 ]; then
        echo ""
        echo "ERROR: help.html generation failed — commit aborted."
        exit 1
    fi
    git add public/help.html
    echo "help.html regenerated and staged."
fi
